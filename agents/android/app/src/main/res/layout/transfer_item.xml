<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/spacing_md"
    android:paddingBottom="@dimen/spacing_md">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Direction icon container -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="?attr/colorSurfaceContainerHigh">

            <ImageView
                android:id="@+id/transferFileIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/transferDirection"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="@dimen/text_lg"
                android:textColor="?attr/colorOnSurface"
                android:text="⬆" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_md">

            <TextView
                android:id="@+id/transferFilename"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_p"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:ellipsize="middle" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@drawable/bg_input">

                <View
                    android:id="@+id/transferProgressFill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/progress_gradient"
                    android:importantForAccessibility="no" />
            </FrameLayout>

            <ProgressBar
                android:id="@+id/transferSparkline"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="2dp"
                android:progressDrawable="@drawable/progress_gradient"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/transferProgressText"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/text_xs" />

                <TextView
                    android:id="@+id/transferSpeedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="?attr/colorPrimary"
                    android:textSize="@dimen/text_xs"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/transferCancelBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/cd_cancel"
            android:background="@drawable/bg_circle"
            android:scaleType="center"
            android:importantForAccessibility="yes" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/spacing_md"
        android:background="?attr/colorOutlineVariant" />
</LinearLayout>
