<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <!-- ═══ TRANSFER TAB ═══ -->
        <ScrollView
            android:id="@+id/layoutSend"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_xl">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send files"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="@dimen/spacing_xxxl"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share instantly with nearby devices"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="20dp" />

                <!-- Action Buttons Row (macOS style) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- Files Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnFiles"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/cardFill"
                        app:strokeColor="@color/cardStroke"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.R16">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_files"
                                android:contentDescription="Files"
                                app:tint="@color/md_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Files"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="@dimen/spacing_sm" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Photos Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnPhotos"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="@dimen/spacing_xs"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/cardFill"
                        app:strokeColor="@color/cardStroke"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.R16">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_photos"
                                android:contentDescription="Photos"
                                app:tint="@color/md_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Photos"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="@dimen/spacing_sm" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Text Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnText"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/cardFill"
                        app:strokeColor="@color/cardStroke"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.R16">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_text"
                                android:contentDescription="Text"
                                app:tint="@color/md_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Text"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="@dimen/spacing_sm" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Selected Files Card (macOS Selection card style) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFileQueue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/cardFill"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Premium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <!-- Header row: title + count + close -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Selection"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvFileCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvFileTotalSize"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <ImageButton
                                android:id="@+id/btnClearFiles"
                                android:layout_width="@dimen/touch_icon"
                                android:layout_height="@dimen/touch_icon"
                                android:src="@drawable/ic_close"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Clear selection"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:layout_marginStart="@dimen/spacing_sm" />
                        </LinearLayout>

                        <!-- Thumbnail horizontal scroll -->
                        <HorizontalScrollView
                            android:id="@+id/fileThumbnailList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/thumbnailContainer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />
                        </HorizontalScrollView>

                        <!-- Edit + Add buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:orientation="horizontal"
                            android:gravity="end">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnEditFiles"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Edit"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAddFiles"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:text="Add" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Nearby Devices header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvNearbyLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nearby Devices"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <ImageButton
                        android:id="@+id/btnManualIp"
                        android:layout_width="@dimen/touch_icon"
                        android:layout_height="@dimen/touch_icon"
                        android:src="@drawable/ic_search"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Manual IP"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <ImageButton
                        android:id="@+id/btnRefreshScan"
                        android:layout_width="@dimen/touch_icon"
                        android:layout_height="@dimen/touch_icon"
                        android:src="@drawable/ic_sync"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Refresh scan"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <View
                        android:id="@+id/scanningDot"
                        android:layout_width="@dimen/spacing_sm"
                        android:layout_height="@dimen/spacing_sm"
                        android:background="@color/md_primary"
                        android:visibility="gone"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:importantForAccessibility="no" />
                </LinearLayout>

                <!-- Device list RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDiscoveredDevices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/tvNoDevices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No devices found"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/spacing_xxl"
                    android:visibility="visible" />

                <!-- Troubleshoot link -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTroubleshoot"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Troubleshoot"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <!-- Help text -->
                <TextView
                    android:id="@+id/tvHelpText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Share files between devices on the same network."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_xxxl" />
            </LinearLayout>
        </ScrollView>

        <!-- ═══ DEVICES TAB (was Receive) ═══ -->
        <ScrollView
            android:id="@+id/layoutReceive"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_xl"
                android:gravity="center_horizontal">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Devices"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="@dimen/spacing_xxxl"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage connected devices"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="20dp" />

                <!-- Device info card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    app:cardBackgroundColor="@color/cardFill"
                    app:strokeColor="@color/cardStroke"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Premium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/receiveLogo"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_logo"
                            android:contentDescription="Logo"
                            app:tint="@color/md_primary" />

                        <TextView
                            android:id="@+id/tvReceiveDeviceName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="@dimen/spacing_md" />

                        <TextView
                            android:id="@+id/tvReceiveIp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                            android:layout_marginTop="@dimen/spacing_xs" />

                        <TextView
                            android:id="@+id/tvReceiveStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ready to receive files"
                            android:textColor="@color/md_primary"
                            android:textSize="13sp"
                            android:layout_marginTop="@dimen/spacing_sm" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Active transfers panel -->
                <LinearLayout
                    android:id="@+id/activeTransfersPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Active Transfers"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvActiveTransfers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>

                <!-- History panel -->
                <LinearLayout
                    android:id="@+id/historyPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/spacing_xxxl">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="History"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearHistory"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clear"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTransferHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- ═══ SETTINGS TAB ═══ -->
        <ScrollView
            android:id="@+id/layoutSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_xl">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="@dimen/spacing_xxxl"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configure your preferences"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="24dp" />

                <!-- GENERAL section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GENERAL"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_primary"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Section card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    app:cardBackgroundColor="@color/settingsRowBg"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Premium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Auto-connect row -->
                        <LinearLayout
                            android:id="@+id/rowTheme"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Theme"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvThemeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="System"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <!-- Color mode row -->
                        <LinearLayout
                            android:id="@+id/rowColorMode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Color"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvColorModeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dynamic"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SECURITY section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SECURITY"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_primary"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    app:cardBackgroundColor="@color/settingsRowBg"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Premium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Auto-accept row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Auto-accept files"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchAutoAccept"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <!-- Encryption row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="TLS encryption"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchEncryption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <!-- PIN row -->
                        <LinearLayout
                            android:id="@+id/rowPinCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="PIN code"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvPinCodeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="None"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SHARING section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SHARING"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_primary"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    app:cardBackgroundColor="@color/settingsRowBg"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Premium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Device name row -->
                        <LinearLayout
                            android:id="@+id/rowDeviceName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Device name"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvDeviceNameValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <!-- Save location row -->
                        <LinearLayout
                            android:id="@+id/rowSaveLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Save location"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvSaveLocationValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <!-- ZIP on receive row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Receive as ZIP"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchZip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ABOUT section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_primary"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xxxl"
                    app:cardBackgroundColor="@color/settingsRowBg"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Premium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Version row -->
                        <LinearLayout
                            android:id="@+id/rowVersion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Version"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvVersionValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <!-- Clear history row -->
                        <LinearLayout
                            android:id="@+id/rowClearHistory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Clear history"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tvClearHistoryCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <!-- Licenses row -->
                        <LinearLayout
                            android:id="@+id/rowLicenses"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:paddingHorizontal="@dimen/spacing_lg"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Open source licenses"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurface" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="?attr/colorSurface"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
