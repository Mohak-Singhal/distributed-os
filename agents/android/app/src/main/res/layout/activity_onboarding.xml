<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xxl">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/onboardingPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/spacing_xxxl" />

    <!-- Page indicator dots -->
    <LinearLayout
        android:id="@+id/dotsIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_lg"
        android:orientation="horizontal" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxl"
        android:layout_marginBottom="@dimen/spacing_xxl"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/touch_min"
            android:gravity="center"
            android:text="@string/onboarding_skip"
            android:textColor="@color/textTertiary"
            android:textSize="@dimen/text_p"
            android:fontFamily="sans-serif-medium"
            android:clickable="true"
            android:focusable="true" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/touch_min"
            android:minWidth="120dp"
            android:paddingStart="@dimen/spacing_xxl"
            android:paddingEnd="@dimen/spacing_xxl"
            android:text="@string/onboarding_next"
            android:textColor="@color/onPrimary"
            android:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/corner_full"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>
</LinearLayout>
