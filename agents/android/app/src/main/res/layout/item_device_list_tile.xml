<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Premium">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvDeviceAvatar"
            android:layout_width="@dimen/device_avatar_size"
            android:layout_height="@dimen/device_avatar_size"
            android:layout_margin="@dimen/spacing_md"
            android:gravity="center"
            android:textSize="20sp"
            android:background="@drawable/device_avatar_bg" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_p"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvDeviceSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_md"
                android:singleLine="true" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDeviceBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="@dimen/text_sm"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorPrimary"
            android:visibility="gone"
            android:layout_marginEnd="@dimen/spacing_md"
            android:layout_marginStart="@dimen/spacing_sm" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
